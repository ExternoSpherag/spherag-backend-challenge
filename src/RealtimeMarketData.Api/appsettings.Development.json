{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=RealtimeMarketData.Dev.db"
  },
  "MarketData": {
    "Ingestion": {
      "ChannelCapacity": 500
    },
    "Streaming": {
      "Binance": {
        "StreamUrl": "wss://fstream.binance.com/stream?streams=btcusdt@trade/ethusdt@trade/dogeusdt@trade"
      },
      "WebSocket": {
        "ReceiveBufferSize": 65536,
        "BaseReconnectDelaySeconds": 1,
        "MaxReconnectDelaySeconds": 30,
        "MaxReconnectAttempts": 8,
        "ConnectTimeoutSeconds": 30,
        "CloseTimeoutSeconds": 5
      }
    },
    "Alerts": {
      "PriceChangeThresholdPercent": 5
    }
  }
}
