<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Official NuGet.org feed -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    
    <!-- Uncomment to add additional package sources -->
    <!-- <add key="MyGet" value="https://www.myget.org/F/feed-name/api/v3/index.json" /> -->
    <!-- <add key="Local" value="./packages" /> -->
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <config>
    <!-- Repository path relative to solution -->
    <add key="repositoryPath" value="packages" />
    
    <!-- Disable package source discovery -->
    <add key="disableSourceControlIntegration" value="true" />
  </config>

  <packageRestore>
    <!-- Allow NuGet to download missing packages -->
    <add key="enabled" value="True" />
    
    <!-- Automatically check for missing packages during build -->
    <add key="automatic" value="True" />
  </packageRestore>

  <bindingRedirects>
    <!-- Automatically generate binding redirects -->
    <add key="skip" value="False" />
  </bindingRedirects>

  <packageManagement>
    <!-- Use PackageReference format -->
    <add key="format" value="1" />
    <add key="disabled" value="False" />
  </packageManagement>

</configuration>
