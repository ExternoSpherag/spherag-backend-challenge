## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
**/*.rsuser
**/*.suo
**/*.user
**/*.userosscache
**/*.sln.docstates

# Build results
**/[Dd]ebug/
**/[Dd]ebugPublic/
**/[Rr]elease/
**/[Rr]eleases/
**/x64/
**/x86/
**/[Ww][Ii][Nn]32/
**/[Aa][Rr][Mm]/
**/[Aa][Rr][Mm]64/
**/bld/
**/[Bb]in/
**/[Oo]bj/
**/[Ll]og/
**/[Ll]ogs/
**/artifacts/

# Visual Studio cache/options directory
**/.vs/
**/.vscode/
**/.idea/

# Test Results
**/[Tt]est[Rr]esult*/
**/[Bb]uild[Ll]og.*
**/*.VisualState.xml
**/TestResult.xml
**/nunit-*.xml

# .NET
**/project.lock.json
**/project.fragment.lock.json

# Files built by Visual Studio
**/*.ilk
**/*.meta
**/*.obj
**/*.iobj
**/*.pch
**/*.pdb
**/*.ipdb
**/*.pgc
**/*.pgd
**/*.rsp
**/*.sbr
**/*.tlb
**/*.tli
**/*.tlh
**/*.tmp
**/*.tmp_proj
**/*_wpftmp.csproj
**/*.log
**/*.tlog
**/*.vspscc
**/*.vssscc
**/.builds
**/*.pidb
**/*.svclog
**/*.scc

# Visual C++ cache files
**/ipch/
**/*.aps
**/*.ncb
**/*.opendb
**/*.opensdf
**/*.sdf
**/*.cachefile
**/*.VC.db
**/*.VC.VC.opendb

# ReSharper
**/_ReSharper*/
**/*.[Rr]e[Ss]harper
**/*.DotSettings.user

# TeamCity
**/_TeamCity*

# DotCover
**/*.dotCover

# Coverage
**/.axoCover/
**/coverage*.json
**/coverage*.xml
**/coverage*.info
**/*.coverage
**/*.coveragexml

# NCrunch
**/_NCrunch_*
**/.*.crunch*.local.xml
**/nCrunchTemp_*

# NuGet Packages
**/*.nupkg
**/*.snupkg
**/[Pp]ackages/

# Database files
**/*.dbmdl
**/*.dbproj.schemaview
**/*.jfm
**/*.mdf
**/*.ldf
**/*.ndf

# Node.js
**/node_modules/
**/npm-debug.log

# JetBrains Rider
**/*.sln.iml

# Docker
**/.dockerignore
**/docker-compose*
**/Dockerfile*
**/.git
**/.gitignore
**/.gitattributes

# Documentation
**/*.md
!README.md

# Azure
**/azds.yaml
**/charts/
**/secrets.dev.yaml
**/values.dev.yaml

# CI/CD
**/.github/
**/.azuredevops/

# Environment
**/.env
**/.env.local
**/.env.*.local

# IDE
**/.project
**/.settings
**/.classpath
**/.toolstarget
**/*.pfx
**/*.publishsettings

# Git metadata (keep minimal for CI)
!.git/HEAD
!.git/config
!.git/packed-refs
!.git/refs/heads/**